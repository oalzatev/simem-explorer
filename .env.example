# SIMEM Explorer — Variables de entorno
# Copia este archivo como .env y ajusta los valores

# Puerto del servidor (default: 5000)
PORT=5000

# Ruta donde se guardan los CSV exportados
# En Docker, usa una ruta dentro del contenedor que mapeas a un volumen
SIMEM_EXPORT_PATH=./exports

# Entorno de ejecución (development | production)
NODE_ENV=production
